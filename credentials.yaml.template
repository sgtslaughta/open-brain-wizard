# open-brain-wizard credentials (YAML)
# Copy this file to credentials.yaml and fill in the values.
# Scripts (link, set-secrets) read from credentials.yaml. Never commit credentials.yaml.
#
# Supabase access token: for 'supabase link' only (e.g. 1-hour token for installer run). Get at supabase.com/dashboard/account/tokens
# Get project_ref from Supabase dashboard URL: .../project/THIS_PART
# Get openrouter_api_key from openrouter.ai/keys
# Get slack_bot_token and slack_capture_channel from Slack app (OAuth & Permissions; channel details)
# Generate mcp_access_key with: openssl rand -hex 32  (or scripts will prompt)

supabase_access_token: ""
project_ref: "YOUR_PROJECT_REF"
db_password: ""
openrouter_api_key: "sk-or-v1-..."
slack_bot_token: "xoxb-..."
slack_capture_channel: "C0..."
mcp_access_key: ""
